---
import Layout from '../layouts/Layout.astro';

const city = "Austin";
const state = "TX";
const heroImage = "/images/cities/austin-tx.jpg";
const ctaHeader = "Schedule Your Sparkling Clean Today!";
const ctaSubheader = "Experience the results that only Sunshine Maids can provide. Our professional cleaners are ready to transform your home into a haven.";

const neighborhoods = [
  "Tarrytown",
  "Midtown",
  "Bricktown",
  "Heritage Hills",
  "Mesta Park",
  "Capitol Hill",
  "Deep Deuce",
  "Paseo",
  "Greater Uptown",
  "Crown Heights",
  "Lakewood",
  "Edgemere Park"
];

const services = [
  { name: "Basic House Cleaning", href: "/services/basic-house-cleaning", image: "/images/basic-house-cleaning.jpg" },
  { name: "Deep House Cleaning", href: "/services/deep-house-cleaning", image: "/images/deep-house-cleaning.jpg" },
  { name: "Move-In/Move-Out Cleaning", href: "/services/move-in-move-out-cleaning", image: "/images/movein-moveout-cleaning.jpg" },
  { name: "Recurring Maid Services", href: "/services/recurring-maid-services", image: "/images/recurring-maid-services.jpg" },
  { name: "Airbnb Cleaning", href: "/services/airbnb-cleaning", image: "/images/airbnb-cleaning.jpg" },
  { name: "Commercial Cleaning", href: "/services/commercial-cleaning", image: "/images/commercial-cleaning.jpg" },
  { name: "Post-Construction Cleaning", href: "/services/post-construction-cleaning", image: "/images/post-construction-cleaning.jpg" },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Sunshine Maids",
  "telephone": "+1-512-555-0147",
  "email": "hello@sunshinemaids.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1847 South Lamar Blvd",
    "addressLocality": "Austin",
    "addressRegion": "TX",
    "postalCode": "78704"
  },
  "areaServed": [`${city}, ${state}`, ...neighborhoods.map(n => `${n}, ${city}, ${state}`)],
  "priceRange": "$$"
};
---

<Layout 
  title={`House Cleaning Services in ${city}, ${state} | Sunshine Maids`}
  description={`Professional house cleaning services in ${city}, ${state}. Sunshine Maids serves ${neighborhoods.slice(0, 3).join(', ')}, and all ${city} neighborhoods. Book your free estimate today!`}
  canonical={`/house-cleaning-austin-tx`}
  schema={schema}
>
  <!-- Hero: Split layout with city image -->
  <section class="relative bg-coral overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 min-h-[400px] md:min-h-[500px]">
        <!-- Image Side -->
        <div class="relative h-64 md:h-auto order-2 md:order-1">
          <img 
            src={heroImage} 
            alt={`${city}, Texas`}
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>
        <!-- Content Side -->
        <div class="flex flex-col justify-center px-8 md:px-12 lg:px-16 py-12 md:py-16 order-1 md:order-2">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
            {city}, {state} Cleaning Services
          </h1>
          <p class="text-lg text-white/90 mb-8 max-w-lg">
            Professional residential cleaning services for families across {city}. From weekly maintenance to deep cleaning, we keep your home spotless so you can focus on what matters.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href="tel:+14059774237"
              class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-center"
            >
              Call (512) 555-0147
            </a>
            <a 
              href="/contact"
              class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-all duration-200 text-center"
            >
              Get a Free Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services We Offer in [City] -->
  <section class="py-16 md:py-20 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Services</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Services We Provide in {city}, {state}</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        {services.slice(0, 3).map(service => (
          <a href={service.href} class="group relative h-64 rounded-xl overflow-hidden block hover:-translate-y-1 transition-all duration-300 shadow-md hover:shadow-xl">
            <img src={service.image} alt={`${service.name} in ${city}`} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-white text-xl font-bold">{service.name}</h3>
              <span class="text-white/80 text-sm font-medium mt-1 inline-block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.slice(3).map(service => (
          <a href={service.href} class="group relative h-52 rounded-xl overflow-hidden block hover:-translate-y-1 transition-all duration-300 shadow-md hover:shadow-xl">
            <img src={service.image} alt={`${service.name} in ${city}`} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="text-white text-lg font-bold">{service.name}</h3>
              <span class="text-white/80 text-sm font-medium mt-1 inline-block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
          Your Trusted {city} House Cleaning Service
        </h2>
        
        <div class="prose prose-lg text-text-light mb-10">
          <p>
            Sunshine Maids has been serving Austin residents with professional house cleaning services for years. We understand that your home is your sanctuary, and maintaining a clean living space is essential for your health and wellbeing. Whether you need a one-time deep clean or recurring maintenance, our team of experienced cleaning professionals is dedicated to delivering exceptional results.
          </p>
          <p>
            Austin residents trust Sunshine Maids because we treat every home as if it were our own. Our attention to detail and commitment to customer satisfaction has made us one of the most recommended cleaning services in the metro area. We use proven cleaning techniques and quality products to ensure your home sparkles from room to room.
          </p>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
          {city} Neighborhoods We Serve
        </h2>
        
        <p class="text-text-light mb-6">
          We proudly provide house cleaning services to residents across all {city} communities, including:
        </p>
        
        <div class="flex flex-wrap gap-3 mb-10">
          {neighborhoods.map(area => (
            <span class="px-4 py-2 bg-white text-gray-700 rounded-full shadow-sm border border-gray-200">
              {area}
            </span>
          ))}
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
          Why {city} Families Choose Sunshine Maids
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="bg-white p-6 rounded-xl shadow-sm hover:-translate-y-0.5 transition-all duration-200">
            <div class="w-12 h-12 bg-coral rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-semibold text-text mb-2">Local {city} Business</h3>
            <p class="text-text-light text-sm">We're proud to call the Austin metro home. We know {city} neighborhoods and work hard to be a part of this community.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm hover:-translate-y-0.5 transition-all duration-200">
            <div class="w-12 h-12 bg-coral rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-text mb-2">Family-Safe Products</h3>
            <p class="text-text-light text-sm">We use cleaning products that are safe for children and pets. Your family's health and safety come first in every home we clean.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm hover:-translate-y-0.5 transition-all duration-200">
            <div class="w-12 h-12 bg-coral rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-text mb-2">Insured & Vetted Cleaners</h3>
            <p class="text-text-light text-sm">Every cleaner is background checked and fully insured. You can trust the people in your {city} home.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm hover:-translate-y-0.5 transition-all duration-200">
            <div class="w-12 h-12 bg-coral rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <h3 class="font-semibold text-text mb-2">Satisfaction Guaranteed</h3>
            <p class="text-text-light text-sm">We're not happy unless you're happy. If anything isn't up to your standards, we'll make it right.</p>
          </div>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
          Frequently Asked Questions
        </h2>
        
        <div class="space-y-6">
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <h3 class="font-semibold text-text mb-2">How much does house cleaning cost in {city}?</h3>
            <p class="text-text-light">Our {city} cleaning services are priced based on your home's size and the type of cleaning you need. We offer free estimates, so contact us to get a personalized quote.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <h3 class="font-semibold text-text mb-2">Do you offer recurring cleaning for {city} families?</h3>
            <p class="text-text-light">Yes! We offer weekly, bi-weekly, and monthly plans designed around {city} families' schedules. Regular cleanings keep your home consistently fresh.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <h3 class="font-semibold text-text mb-2">What areas of {city} do you serve?</h3>
            <p class="text-text-light">We serve all {city} neighborhoods from {neighborhoods[0]} and {neighborhoods[1]} to {neighborhoods[2]} and {neighborhoods[3]}. If you're in {city}, we can help.</p>
          </div>
          
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <h3 class="font-semibold text-text mb-2">Are your cleaning supplies included?</h3>
            <p class="text-text-light">Absolutely. We bring everything needed for a thorough clean. Just point us to the areas that need attention, and we'll handle the rest.</p>
          </div>
        </div>

        <!-- Local Testimonial -->
        <div class="mt-12 bg-white p-8 rounded-xl shadow-sm border-l-4 border-coral">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            </div>
            <div>
              <p class="text-text-light italic mb-3">"Sunshine Maids has been keeping our Austin home spotless for years. Their attention to detail is incredible, and they always show up on time. Whether we're in Tarrytown or downtown, they treat every room like it's their own. Couldn't recommend them more highly!"</p>
              <p class="font-semibold text-text">— Austin Resident</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dream Outcome CTA: Full-bleed image background -->
  <section class="relative py-20 md:py-28">
    <img 
      src="/images/house-cleaning.jpg" 
      alt="Clean, spotless home" 
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        {ctaHeader}
      </h2>
      <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
        {ctaSubheader}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+14059774237"
          class="bg-coral text-white px-10 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          Call Now
        </a>
        <a 
          href="/contact"
          class="bg-white text-text px-10 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          Book My Free Estimate
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
