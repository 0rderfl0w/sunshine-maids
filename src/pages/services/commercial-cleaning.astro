---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Professional Commercial Cleaning Services | Guardian Cleaners"
  description="Guardian Cleaners offers professional commercial cleaning in Oklahoma City. Offices, retail, healthcare, and more. Customized plans, flexible scheduling. Book your free estimate today!"
  canonical="/services/commercial-cleaning"
>
  <!-- Hero -->
  <section class="relative pt-20 pb-32 md:pt-28 md:pb-40 bg-coral">
    <div class="absolute top-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="margin-bottom: -1px;">
        <path d="M0 60H1440V0C1200 40 960 60 720 30C480 0 240 20 0 50V60Z" fill="white"/>
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Professional Commercial Cleaning Services</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto mb-8">
        Offering exceptional Commercial Cleaning solutions, our team is committed to providing top-quality services to meet all your needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (405) 977-4237
        </a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="margin-top: -1px;">
        <path d="M0 0H1440V60C1200 20 960 0 720 30C480 60 240 40 0 10V0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Our Service</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Commercial Cleaning</h2>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            Guardian Cleaners LLC offers commercial cleaning services designed to keep your business pristine and welcoming. We understand office spaces and commercial areas need regular thorough cleaning to make a good impression on clients and provide a healthy environment for employees.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            Every business is unique. Our commercial cleaning services can be customized to fit the schedule and scope you require—be it daily, weekly, or monthly cleanings. Our network of cleaners are thoroughly vetted and come with the experience necessary to deliver exceptional cleaning standards which minimize disruption to your day-to-day operations.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            Guardian Cleaners LLC is committed to providing reliable, high-quality cleaning services in a professional manner. We pride ourselves on punctuality and attention to detail, ensuring that you receive quality results you can trust every time.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Dusting, vacuuming, and thorough trash removal</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Restroom sanitation and kitchen cleaning</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Floor care and window cleaning</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Customized plans for daily, weekly, or monthly service</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Off-hours cleaning available to minimize business disruption</span>
            </li>
          </ul>
        </div>
        <div>
          <img
            src="/images/commercial-cleaning.jpg"
            alt="Commercial Cleaning by Guardian Cleaners"
            class="w-full rounded-2xl shadow-xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Delivering top-notch cleaning solutions for your business.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <h3 class="font-bold text-text mb-3">On-site Assessment and Custom Quote</h3>
          <p class="text-text-light text-sm leading-relaxed">We meet at your business location to discuss your cleaning needs. By assessing the space and understanding your specific requirements, we provide a customized quote tailored to your business.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <h3 class="font-bold text-text mb-3">Flexible Scheduling and Detailed Planning</h3>
          <p class="text-text-light text-sm leading-relaxed">We work with you to schedule cleanings at times that won't disrupt your business. We develop a strategic plan taking into account resource allocation, while ensuring minimal disruption.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <h3 class="font-bold text-text mb-3">Thorough Cleaning by Trusted Professionals</h3>
          <p class="text-text-light text-sm leading-relaxed">Our skilled cleaners efficiently carry out the detailed cleaning, adhering strictly to industry standards. Inspecting every detail, we ensure your premises are clean and welcoming for both employees and customers.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">4</span>
          </div>
          <h3 class="font-bold text-text mb-3">Follow-up and Satisfaction Assurance</h3>
          <p class="text-text-light text-sm leading-relaxed">Post-cleaning, we conduct a walkthrough with you, addressing any areas of concern. We remain available for immediate follow-up to ensure your complete satisfaction.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">FAQs</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Common Questions</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What types of businesses can benefit from your commercial cleaning service?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our commercial cleaning service is perfect for various businesses including offices, retail stores, healthcare facilities, and more. If your business needs to stay sparkling clean, we can tailor our services to match your needs.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How often can we schedule cleanings?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">We offer flexible scheduling options to meet your business's needs, whether you require daily, weekly, or monthly cleaning services.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Are the cleaners experienced with commercial spaces?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Yes, our cleaners have extensive experience in commercial cleaning. They know how to tackle different environments to ensure your space is spotless and welcoming.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What is included in your commercial cleaning service?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our service includes dusting, vacuuming, mopping, restroom sanitation, and more. We can customize our cleaning plans to fit the specific needs of your business.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Do you provide services outside of regular business hours?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Absolutely. We understand the need for flexible service times and can provide cleaning services during off-hours to minimize disruption to your business operations.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How can I book a commercial cleaning service with Guardian Cleaners LLC?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Booking with us is easy. Simply call us at (405) 977-4237 or visit our office at 3129 NW 14th St, Oklahoma City, to get started.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-coral animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Book Your Spot Today!</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Transform your workspace with our thorough commercial cleaning services—call now for a spotless tomorrow!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (405) 977-4237
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
