---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Professional Basic House Cleaning Services | Sunshine Maids"
  description="Sunshine Maids offers reliable basic house cleaning in Austin. Dusting, vacuuming, bathrooms, kitchens, and more. Book your free estimate today!"
  canonical="/services/basic-house-cleaning"
>
  <!-- Hero -->
  <section class="relative min-h-[500px] md:min-h-[600px] flex items-center">
    <div class="absolute inset-0">
      <img 
        src="/images/basic-house-cleaning.jpg" 
        alt="Basic house cleaning services"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 max-w-3xl">Professional Basic House Cleaning Services</h1>
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-8">Offering exceptional Basic House Cleaning solutions, our team is committed to providing top-quality services to meet all your needs.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center bg-coral text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (512) 555-0147
        </a>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
          <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Our Service</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Basic House Cleaning</h2>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            At Sunshine Maids LLC, we understand that maintaining a clean home is crucial for your comfort and well-being. With our Basic House Cleaning service, you can enjoy a spotless and fresh home without getting your hands dirty.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            Our reliable cleaning experts will manage routine cleaning tasks with precision and care, allowing you more free time to do what you love. This service includes dusting all surfaces, vacuuming floors, scrubbing bathroom fixtures, and thoroughly cleaning kitchen areas. We pay special attention to those often-forgotten nooks and crannies that build up dirt over time.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            Booking our Basic House Cleaning service means you'll have a consistent level of cleanliness that you can count on, enhancing both the beauty and hygiene of your living space. Whether you need a regular tidy-up or a one-off cleaning boost, our approach ensures attention to detail tailored just for your home's needs.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Dusting all surfaces, ceiling fans, and baseboards</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Vacuuming carpets and mopping hard floors</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Scrubbing and sanitizing bathroom fixtures</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Thorough kitchen cleaning including counters and appliances</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Attention to nooks and crannies that build up dirt over time</span>
            </li>
          </ul>
        </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Delivering fresh and clean homes with precision and care.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <h3 class="font-bold text-text mb-3">Easy Booking & Customization</h3>
          <p class="text-text-light text-sm leading-relaxed">Contact Sunshine Maids at (512) 555-0147 to schedule your cleaning. Discuss your preferences, areas of focus, and choose a convenient date.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <h3 class="font-bold text-text mb-3">Pre-Service Confirmation</h3>
          <p class="text-text-light text-sm leading-relaxed">A friendly confirmation call is made the day before your scheduled cleaning, ensuring all details are correct and giving you peace of mind.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <h3 class="font-bold text-text mb-3">Professional Cleaning & Care</h3>
          <p class="text-text-light text-sm leading-relaxed">Our cleaners arrive promptly at the appointed time, equipped to tackle your home, following specific care details and addressing areas requiring special attention.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">4</span>
          </div>
          <h3 class="font-bold text-text mb-3">Final Touch & Feedback</h3>
          <p class="text-text-light text-sm leading-relaxed">After completing the cleaning, we ensure your satisfaction through a brief walk-through. We welcome your feedback to ensure our services perfectly meet your expectations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">FAQs</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Common Questions</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What areas do you serve?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">We proudly offer our Basic House Cleaning services in and around our local community. Feel free to call us at (512) 555-0147 to see if we can serve your area.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How do I schedule a cleaning?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Scheduling a cleaning with us is simple. Just call (512) 555-0147, and we'll help you set an appointment that fits your schedule.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What does Basic House Cleaning include?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our Basic House Cleaning service covers essential cleaning tasks such as dusting, vacuuming, sweeping, mopping, and bathroom cleaning to keep your home fresh and tidy.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How long does a typical cleaning take?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">The duration of the cleaning depends on the size and condition of your home, but most Basic House Cleanings typically take a few hours. We aim to be efficient without compromising quality.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Do I need to be home during the cleaning?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">It's not necessary to be home while we clean your house. You can trust our cleaners to do a great job and secure your home when they're done.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Are your cleaners insured?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Yes, our cleaners come with the assurance of being fully insured, providing you with peace of mind while we care for your home.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Experience Spotless Living Today!</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Ready to enjoy a consistently clean home? Let our professionals take care of it.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (512) 555-0147
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
