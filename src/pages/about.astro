---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About Us - Sunshine Maids"
  description="Learn about Sunshine Maids - a locally owned cleaning company serving Austin, Round Rock, Cedar Park and surrounding areas with professional residential and commercial cleaning services."
  canonical="/about"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 items-center">
        <!-- Text Side -->
        <div class="px-6 sm:px-10 lg:px-16 xl:px-20 py-16 md:py-24 order-2 lg:order-1">
          <span class="inline-block bg-coral/10 text-coral font-semibold uppercase tracking-widest text-xs px-4 py-1.5 rounded-full mb-6">About Sunshine Maids</span>
          <h1 class="text-4xl md:text-5xl font-bold text-text mb-5 leading-[1.15]">Expert Cleaning &amp;<br/>Maid Services</h1>
          <p class="text-text-light text-lg leading-relaxed mb-8 max-w-md">
            Trustworthy, thorough, and personalized care for your home. Let us handle the mess so you can enjoy your space worry-free.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact" class="bg-coral text-white px-8 py-3.5 rounded-full text-base font-semibold hover:bg-coral-dark transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-center">
              Book My Free Estimate
            </a>
            <a href="tel:+14059774237" class="bg-text text-white px-8 py-3.5 rounded-full text-base font-semibold hover:bg-text/80 transition-all duration-200 flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (512) 555-0147
            </a>
          </div>
        </div>
        <!-- Image Side -->
        <div class="relative order-1 lg:order-2 min-h-[300px] md:min-h-[400px] lg:min-h-[520px]">
          <img 
            src="/images/cleaning-team.png" 
            alt="The Sunshine Maids team" 
            class="absolute inset-0 w-full h-full object-cover lg:rounded-bl-[80px]"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- Story Section -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Our Story</h2>
      <p class="text-white/90 text-lg leading-relaxed mb-6">
        At Sunshine Maids, our roots trace back to Austin with a heartfelt mission: to help our neighbors across the metro enjoy spotless, healthier homes. From South Austin and Bee Cave to Round Rock and Pflugerville, we're here to transform living and working spaces into immaculate oases.
      </p>
      <p class="text-white/90 text-lg leading-relaxed">
        Our approach is simple yet profound — we don't cut corners, we clean them. By partnering with skilled local cleaners, we provide opportunities that strengthen our community. Our commitment is more than just professional service; it's building trust and fostering relationships.
      </p>
    </div>
  </section>

  <!-- Wave: coral → white -->
  <div class="bg-coral">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" style="margin-bottom: -1px;">
      <path d="M0 40C360 0 720 80 1080 40C1260 20 1380 30 1440 40V80H0V40Z" fill="#f9fafb"/>
    </svg>
  </div>

  <!-- Why Choose Us -->
  <section class="py-14 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block bg-coral/10 text-coral font-semibold uppercase tracking-widest text-xs px-4 py-1.5 rounded-full mb-4">Why Us</span>
        <h2 class="text-3xl md:text-4xl font-bold text-text">The Sunshine Difference</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-7 rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 text-center group">
          <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-coral/20 transition-colors duration-300">
            <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Locally Owned</h3>
          <p class="text-text-light text-sm leading-relaxed">Proud to serve our Austin community with care</p>
        </div>
        <div class="bg-white p-7 rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 text-center group">
          <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-coral/20 transition-colors duration-300">
            <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Flexible Scheduling</h3>
          <p class="text-text-light text-sm leading-relaxed">We work around your busy schedule</p>
        </div>
        <div class="bg-white p-7 rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 text-center group">
          <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-coral/20 transition-colors duration-300">
            <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Trusted Professionals</h3>
          <p class="text-text-light text-sm leading-relaxed">Background-checked cleaning experts</p>
        </div>
        <div class="bg-white p-7 rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 text-center group">
          <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-coral/20 transition-colors duration-300">
            <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Satisfaction Guaranteed</h3>
          <p class="text-text-light text-sm leading-relaxed">We don't leave until you're happy</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="inline-block bg-coral/10 text-coral font-semibold uppercase tracking-widest text-xs px-4 py-1.5 rounded-full mb-4">Services</span>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Our Expert Cleaning Services</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        <a href="/services/basic-house-cleaning" class="group relative h-64 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/basic-house-cleaning.jpg" alt="Basic house cleaning in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-white text-xl font-bold">Basic House Cleaning</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
        <a href="/services/deep-house-cleaning" class="group relative h-64 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/deep-house-cleaning.jpg" alt="Deep house cleaning in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-white text-xl font-bold">Deep House Cleaning</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
        <a href="/services/move-in-move-out-cleaning" class="group relative h-64 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/movein-moveout-cleaning.jpg" alt="Move-in move-out cleaning in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-white text-xl font-bold">Move-In/Move-Out Cleaning</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/services/recurring-maid-services" class="group relative h-52 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/recurring-maid-services.jpg" alt="Recurring maid services in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-white text-lg font-bold">Recurring Maid Services</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
        <a href="/services/airbnb-cleaning" class="group relative h-52 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/airbnb-cleaning.jpg" alt="Airbnb cleaning in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-white text-lg font-bold">Airbnb Cleaning</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
        <a href="/services/commercial-cleaning" class="group relative h-52 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/commercial-cleaning.jpg" alt="Commercial cleaning in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-white text-lg font-bold">Commercial Cleaning</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
        <a href="/services/post-construction-cleaning" class="group relative h-52 rounded-2xl overflow-hidden block shadow-sm hover:shadow-lg transition-shadow duration-300">
          <img src="/images/post-construction-cleaning.jpg" alt="Post-construction cleaning in Austin" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-white text-lg font-bold">Post-Construction Cleaning</h3>
            <span class="text-white/70 text-sm font-medium mt-1 inline-block group-hover:text-white transition-colors">Learn More →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Experience the Sunshine Difference</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Ready to enjoy a cleaner, healthier home? Let us take care of the work so you can focus on what matters.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (512) 555-0147
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
