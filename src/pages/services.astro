---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    name: "Basic House Cleaning",
    description: "At Guardian Cleaners LLC, we understand that maintaining a clean home is crucial for your comfort and well-being. With our Basic House Cleaning service, you can enjoy a spotless and fresh home without getting your hands dirty. Our reliable cleaning experts will manage routine cleaning tasks with precision and care, allowing you more free time to do what you love.",
    features: [
      "Dusting all surfaces",
      "Vacuuming floors",
      "Scrubbing bathroom fixtures",
      "Thoroughly cleaning kitchen areas",
      "Attention to often-forgotten nooks and crannies"
    ],
    alt: "Basic house cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Deep House Cleaning",
    description: "At Guardian Cleaners LLC, our Deep House Cleaning service is designed to bring your home back to its immaculate state. Our skilled cleaners take the time to address every nook and cranny, ensuring no corner is untouched.",
    features: [
      "Comprehensive dusting including ceiling fans and baseboards",
      "Germ-free surfaces - disinfecting high-touch areas",
      "Detailed kitchen refresh - appliances, cabinets, countertops",
      "Bathroom revival - grout lines and shower fixtures",
      "Floor perfection - tile, wood, and carpet"
    ],
    alt: "Deep house cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Move-In/Move-Out Cleaning",
    description: "Comprehensive cleaning service designed for those transitioning between homes. Ensures your old place is spotless for the next occupant or your new home is ready for you to move in.",
    features: [
      "Complete interior cleaning",
      "Kitchen deep clean",
      "Bathroom sanitization",
      "Floor care - all surfaces",
      "Window cleaning"
    ],
    alt: "Move-in/move-out cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Recurring Maid Services",
    description: "Regular scheduled cleaning services to maintain your home's cleanliness consistently. Flexible scheduling to fit your lifestyle.",
    features: [
      "Weekly, bi-weekly, or monthly visits",
      "Customized cleaning plans",
      "Consistent quality",
      "Reliable and courteous professionals"
    ],
    alt: "Recurring maid services in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Airbnb Cleaning",
    description: "Seamless turnarounds that delight your guests every time. We specialize in delivering cleaning solutions for short-term rental properties.",
    features: [
      "Flexible scheduling for quick turnarounds",
      "Detailed cleaning - kitchen, bathrooms, bedrooms",
      "Fresh linens and towels",
      "Inspection and restocking supplies",
      "Trash removal and bin lining"
    ],
    alt: "Airbnb cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Commercial Cleaning",
    description: "Professional cleaning services for business spaces. We help maintain a clean and productive environment for your employees and customers.",
    features: [
      "Office cleaning",
      "Commercial space sanitization",
      "Flexible scheduling",
      "Professional and reliable staff"
    ],
    alt: "Commercial cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Post-Construction Cleaning",
    description: "Specialized cleaning service after renovation or construction work. We handle the mess so you can enjoy your newly renovated space.",
    features: [
      "Dust and debris removal",
      "Deep cleaning of all surfaces",
      "Window cleaning",
      "Floor care and polishing",
      "Final detail work"
    ],
    alt: "Post-construction cleaning in Oklahoma City, OK — Guardian Cleaners"
  }
];
---

<Layout 
  title="Professional Cleaning Services - Guardian Cleaners"
  description="Guardian Cleaners offers comprehensive cleaning services including basic house cleaning, deep cleaning, move-in/move-out, Airbnb, commercial, and post-construction cleaning in Oklahoma City."
  canonical="/services"
>
  <!-- Header -->
  <section class="bg-gradient-to-br from-gray-50 to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Our Cleaning Services
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Professional residential and commercial cleaning solutions tailored to your needs across the Oklahoma City metro area.
      </p>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {services.map((service, index) => (
          <div class="flex flex-col lg:flex-row gap-8 items-start">
            <!-- Service Image Placeholder -->
            <div class="w-full lg:w-1/3">
              <div class="w-full aspect-video bg-gray-100 rounded-xl flex items-center justify-center">
                <svg class="w-20 h-20 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              </div>
            </div>
            
            <!-- Service Details -->
            <div class="w-full lg:w-2/3">
              <div class="flex items-center gap-3 mb-3">
                <span class="w-10 h-10 bg-[#F56C7E] text-white rounded-full flex items-center justify-center font-bold">
                  {index + 1}
                </span>
                <h2 class="text-2xl md:text-3xl font-bold text-gray-900">{service.name}</h2>
              </div>
              <p class="text-gray-600 text-lg mb-6">{service.description}</p>
              
              <h3 class="font-semibold text-gray-900 mb-3">What's Included:</h3>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
                {service.features.map(feature => (
                  <li class="flex items-center text-gray-600">
                    <svg class="w-5 h-5 mr-2 text-[#F56C7E] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-[#F56C7E]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Need a Custom Cleaning Solution?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Contact us today to discuss your specific cleaning needs. We'll work with you to create a personalized cleaning plan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+14059774237"
          class="bg-white text-[#F56C7E] px-8 py-4 rounded-lg text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg"
        >
          Call Now
        </a>
        <a 
          href="/contact"
          class="border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-[#F56C7E] transition-colors duration-200"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>
</Layout>
