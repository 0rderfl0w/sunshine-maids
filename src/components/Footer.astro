---
const currentYear = new Date().getFullYear();

const business = {
  name: "Guardian Cleaners",
  phone: "(405) 977-4237",
  phoneLink: "+14059774237",
  email: "nik@guardian-cleaners.com",
  address: "3129 NW 14th St, Oklahoma City, OK 73107"
};

const serviceAreas = [
  "Oklahoma City",
  "Edmond",
  "Norman",
  "Bethany",
  "The Village",
  "Nichols Hills",
  "Piedmont",
  "Yukon",
  "Del City",
  "Moore",
  "Mustang",
  "Midwest City",
  "Valley Brook",
  "Arcadia"
];

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/house-cleaning-oklahoma-city', label: 'OKC Cleaning' },
  { href: '/cleaning-services-edmond-ok', label: 'Edmond Cleaning' },
  { href: '/cleaning-services-norman-ok', label: 'Norman Cleaning' }
];
---

<footer class="bg-gray-50 border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Business Info -->
      <div>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">{business.name}</h3>
        <div class="space-y-2 text-gray-600">
          <p class="flex items-start">
            <svg class="w-5 h-5 mr-2 mt-0.5 text-[#F56C7E] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{business.address}</span>
          </p>
          <p class="flex items-center">
            <svg class="w-5 h-5 mr-2 text-[#F56C7E] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${business.phoneLink}`} class="hover:text-[#F56C7E] transition-colors">
              {business.phone}
            </a>
          </p>
          <p class="flex items-center">
            <svg class="w-5 h-5 mr-2 text-[#F56C7E] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${business.email}`} class="hover:text-[#F56C7E] transition-colors">
              {business.email}
            </a>
          </p>
        </div>
      </div>
      
      <!-- Service Areas -->
      <div>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Service Areas</h3>
        <ul class="grid grid-cols-2 gap-2 text-gray-600">
          {serviceAreas.map(area => (
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-[#F56C7E] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {area}
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li>
              <a 
                href={link.href}
                class="text-gray-600 hover:text-[#F56C7E] transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="mt-8 pt-8 border-t border-gray-200">
      <p class="text-center text-gray-500 text-sm">
        &copy; {currentYear} Guardian Cleaners. All rights reserved.
      </p>
    </div>
  </div>
</footer>
