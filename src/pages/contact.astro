---
import Layout from '../layouts/Layout.astro';

const business = {
  name: "Guardian Cleaners",
  phone: "(405) 977-4237",
  phoneLink: "+14059774237",
  email: "nik@guardian-cleaners.com",
  address: "3129 NW 14th St",
  city: "Oklahoma City",
  state: "OK",
  zip: "73107",
  fullAddress: "3129 NW 14th St, Oklahoma City, OK 73107",
  mapsUrl: "https://www.google.com/maps/search/?api=1&query=3129+NW+14th+St+Oklahoma+City+OK+73107"
};

const hours = {
  monFri: "8:00 AM - 6:00 PM",
  sat: "9:00 AM - 4:00 PM",
  sun: "Closed"
};

const serviceAreas = [
  "Oklahoma City", "Edmond", "Norman", "Bethany", "The Village",
  "Nichols Hills", "Piedmont", "Yukon", "Del City", "Moore", "Mustang", "Midwest City"
];
---

<Layout 
  title="Contact Us - Guardian Cleaners"
  description="Contact Guardian Cleaners for professional cleaning services in Oklahoma City, Edmond, Norman and surrounding areas. Call (405) 977-4237 or visit us at 3129 NW 14th St."
  canonical="/contact"
>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 bg-coral">
    <div class="absolute top-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="margin-bottom: -1px;">
        <path d="M0 60H1440V0C1200 40 960 60 720 30C480 0 240 20 0 50V60Z" fill="white"/>
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contact Us</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto">
        Get in touch for a free quote on our professional cleaning services.
      </p>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-text mb-8">Get in Touch</h2>

          <!-- Phone -->
          <div class="flex items-start mb-8">
            <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div class="ml-5">
              <h3 class="font-semibold text-text mb-1">Phone</h3>
              <a href={`tel:${business.phoneLink}`} class="text-2xl font-bold text-coral hover:text-coral-dark transition-colors">
                {business.phone}
              </a>
              <p class="text-sm text-text-light mt-1">Tap to call</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start mb-8">
            <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="ml-5">
              <h3 class="font-semibold text-text mb-1">Email</h3>
              <a href={`mailto:${business.email}`} class="text-lg text-coral hover:text-coral-dark transition-colors">
                {business.email}
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start mb-8">
            <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div class="ml-5">
              <h3 class="font-semibold text-text mb-1">Address</h3>
              <p class="text-lg text-text-light">{business.fullAddress}</p>
              <a href={business.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-coral hover:text-coral-dark text-sm inline-flex items-center mt-2 font-medium">
                Open in Google Maps
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start">
            <div class="w-14 h-14 bg-coral/10 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-7 h-7 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5">
              <h3 class="font-semibold text-text mb-1">Business Hours</h3>
              <div class="text-text-light space-y-1">
                <p>Monday – Friday: {hours.monFri}</p>
                <p>Saturday: {hours.sat}</p>
                <p>Sunday: {hours.sun}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-text mb-8">Find Us</h2>
          <div class="w-full aspect-video bg-gray-100 rounded-2xl overflow-hidden shadow-lg">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3256.123456789!2d-97.52!3d35.48!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDI4JzQ4LjAiTiA5N8KwMzEnMjEuNiJX!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Guardian Cleaners location map"
              class="w-full h-full"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Locations</p>
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">Service Areas</h2>
        <p class="text-text-light">We proudly serve the following areas:</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {serviceAreas.map(area => (
          <span class="px-5 py-2.5 bg-white text-text rounded-full border border-gray-200 font-medium shadow-sm">
            {area}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-coral animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Call us today for a free quote on any of our cleaning services.
      </p>
      <a href={`tel:${business.phoneLink}`} class="inline-block bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg">
        {business.phone}
      </a>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
