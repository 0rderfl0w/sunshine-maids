---
import Layout from '../layouts/Layout.astro';

const aboutStory = `At Guardian Cleaners, our roots trace back to Oklahoma City with a heartfelt mission: to help our neighbors across the metro enjoy spotless, healthier homes. From OKC, Edmond, and Norman to Moore and beyond, we're here to transform living and working spaces into immaculate oases. Our approach is simple yet profound—we don't cut corners, we clean them. By partnering with skilled local cleaners, we provide opportunities that strengthen our community. Our commitment is more than just professional service; it's building trust and fostering relationships. Experience the warmth and reliability we've been proud to offer, backed by a legacy of integrity and dedication.`;
---

<Layout 
  title="About Us - Guardian Cleaners"
  description="Learn about Guardian Cleaners - a locally owned cleaning company serving Oklahoma City, Edmond, Norman and surrounding areas with professional residential and commercial cleaning services."
  canonical="/about"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-50 to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          About Guardian Cleaners
        </h1>
        <p class="text-xl text-gray-600">
          Bringing spotless living to Oklahoma City since day one.
        </p>
      </div>
    </div>
  </section>

  <!-- About Content -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Image Placeholder -->
        <div class="order-2 lg:order-1">
          <div class="w-full aspect-4/3 bg-gray-100 rounded-2xl flex items-center justify-center">
            <svg class="w-24 h-24 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
        </div>
        
        <!-- Story Content -->
        <div class="order-1 lg:order-2">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
            Our Story
          </h2>
          <div class="prose prose-lg text-gray-600">
            <p class="mb-4">{aboutStory}</p>
          </div>
          
          <!-- Why Choose Us -->
          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1">Locally Owned</h3>
              <p class="text-sm text-gray-600">Proud to serve our Oklahoma community</p>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1">Flexible Scheduling</h3>
              <p class="text-sm text-gray-600">We work around your schedule</p>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1">Trusted Professionals</h3>
              <p class="text-sm text-gray-600">Background-checked cleaning experts</p>
            </div>
            
            <div class="bg-gray-50 p-4 rounded-lg">
              <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1">Satisfaction Guaranteed</h3>
              <p class="text-sm text-gray-600">We don't leave until you're happy</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Experience the Guardian Difference
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Ready to enjoy a cleaner, healthier home? Let us take care of the work so you can focus on what matters.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+14059774237"
          class="bg-[#F56C7E] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#e55a6c] transition-colors duration-200 shadow-lg hover:shadow-xl"
        >
          Call Now
        </a>
        <a 
          href="/contact"
          class="border-2 border-[#F56C7E] text-[#F56C7E] px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#F56C7E] hover:text-white transition-colors duration-200"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>
</Layout>
