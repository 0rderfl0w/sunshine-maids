---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Airbnb Cleaning Services | Guardian Cleaners Oklahoma City"
  description="Guardian Cleaners specializes in seamless Airbnb turnarounds that delight your guests every time. Fast, reliable, detail-oriented short-term rental cleaning in OKC."
  canonical="/services/airbnb-cleaning"
>
  <!-- Hero -->
  <section class="relative min-h-[500px] md:min-h-[600px] flex items-center">
    <div class="absolute inset-0">
      <img 
        src="/images/airbnb-cleaning.jpg" 
        alt="Airbnb cleaning services"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 max-w-3xl">Airbnb Cleaning Services</h1>
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-8">Seamless turnarounds that delight your guests every time.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center bg-coral text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (405) 977-4237
        </a>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
          <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Our Service</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Airbnb Cleaning</h2>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            Welcome to Guardian Cleaners LLC's premier Airbnb Cleaning Service. We specialize in delivering seamless turnarounds that are sure to delight your guests at every visit. With years of expertise in handling the unique needs of short-term rental properties, we pride ourselves on offering reliable and thorough cleaning solutions.
          </p>
          <h3 class="font-bold text-text mb-4">What We Offer:</h3>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Flexible Scheduling:</strong> We understand that rental turnovers can be unpredictable. Our service accommodates last-minute bookings, early check-ins, and late check-outs.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Detailed Cleaning:</strong> Our cleaners are detail oriented, leaving no corner overlooked — from kitchen counters and bathrooms to bedrooms and common areas.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Fresh Linens and Towels:</strong> We ensure all linens and towels are fresh and welcoming for every new guest.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Inspection and Restocking:</strong> We conduct final inspections to ensure perfection and restock essential supplies like toilet paper and hand soap.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Trash Removal:</strong> All trash is removed and bins are lined for the next guest.</span>
            </li>
          </ul>
          <h3 class="font-bold text-text mb-4">Why Choose Us:</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Consistently high standards of cleanliness with every turnover</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Skilled and professional cleaners with attention to detail</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Quick availability — book with a simple call to ensure a welcoming experience for your guests</span>
            </li>
          </ul>
        </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Ensuring your rental sparkles for every new guest.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <h3 class="font-bold text-text mb-3">Custom Scheduling & Needs Assessment</h3>
          <p class="text-text-light text-sm leading-relaxed">We start by discussing your unique Airbnb schedule and requirements. Whether it's a quick turnaround or a detailed clean, we cater to your needs.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <h3 class="font-bold text-text mb-3">Meticulous Execution & Quality Assurance</h3>
          <p class="text-text-light text-sm leading-relaxed">Our detail-oriented cleaners jump in with precision, serving consistent results each time. We don't just clean; we elevate guest experiences.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <h3 class="font-bold text-text mb-3">Final Review & Transparent Feedback</h3>
          <p class="text-text-light text-sm leading-relaxed">After cleaning, every corner is double-checked to ensure guest-ready perfection. We then invite feedback to evolve guest satisfaction.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">FAQs</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Common Questions</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What does your Airbnb cleaning service include?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our Airbnb cleaning service covers everything needed for a perfect guest experience. We handle dusting, vacuuming, mopping, sanitizing bathrooms and kitchens, changing linens, and replenishing essential items. We aim for seamless turnarounds that impress your guests.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How quickly can you accommodate a last-minute cleaning request?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">We understand the unpredictable nature of short-term rentals. Our flexible scheduling allows us to accommodate urgent requests whenever possible. It's always best to call us at (405) 977-4237 to discuss your needs.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Do I need to provide cleaning supplies or equipment?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">No, our cleaners come equipped with all the necessary supplies and equipment to get the job done efficiently. You don't have to worry about a thing.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How do you ensure the quality of cleaning?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Quality is a top priority for us. Our trusted network of cleaners are skilled and experienced. We also regularly seek feedback to keep standards high and ensure consistency in our services.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Do I need to be present during the cleaning?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">No, you do not need to be present. Our workflow and clear communication give you peace of mind knowing the property will be ready for your next guest without you having to oversee the process.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Can you handle both small and large properties?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Absolutely! We cater to a variety of property sizes, from cozy studios to larger homes, ensuring each space is cleaned with attention to detail and ready to welcome new guests.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Experience Spotless Living Today!</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Ready to provide a great experience for your guests? Contact Guardian Cleaners LLC to book our Airbnb Cleaning Service.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (405) 977-4237
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
