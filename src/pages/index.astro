---
// Homepage - SSR to fetch latest blog posts
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { createServerClient } from '@supabase/ssr';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

// Create server client
const supabase = createServerClient(
  supabaseUrl,
  supabaseKey,
  {
    cookies: {
      get: (key) => Astro.cookies.get(key)?.value,
      set: (key, value, options) => {
        Astro.cookies.set(key, value, options);
      }
    }
  }
);

// Fetch latest 3 published posts
let latestPosts: any[] = [];
try {
  const { data, error } = await supabase
    .from('posts')
    .select('id, title, slug, excerpt, cover_image, published_at')
    .eq('published', true)
    .order('published_at', { ascending: false })
    .limit(3);
  
  if (!error && data) {
    latestPosts = data;
  }
} catch (e) {
  console.error('Error fetching posts:', e);
}

const hero = {
  headline: "Expert Cleaning Services for Your Home",
  subheadline: "Reliable and Local Cleaning for OKC Homes and Business"
};

const services = [
  {
    name: "Basic House Cleaning",
    description: "Routine cleaning tasks including dusting, vacuuming, scrubbing bathrooms and kitchens",
    image: "/images/service-basic.jpg",
    alt: "Basic house cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Deep House Cleaning",
    description: "Thorough cleaning of every nook and cranny including ceiling fans, baseboards, and appliances",
    image: "/images/service-deep.jpg",
    alt: "Deep house cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Move-In/Move-Out Cleaning",
    description: "Comprehensive cleaning for moving transitions",
    image: "/images/service-movein.jpg",
    alt: "Move-in/move-out cleaning in Oklahoma City, OK — Guardian Cleaners"
  },
  {
    name: "Airbnb Cleaning",
    description: "Turnaround cleaning for short-term rental properties",
    image: "/images/service-airbnb.jpg",
    alt: "Airbnb cleaning in Oklahoma City, OK — Guardian Cleaners"
  }
];

const serviceAreas = [
  "Oklahoma City",
  "Edmond",
  "Norman",
  "Bethany",
  "The Village",
  "Nichols Hills",
  "Piedmont",
  "Yukon",
  "Del City",
  "Moore",
  "Mustang",
  "Midwest City"
];

// Placeholder testimonials - Nick to provide Google Reviews
const testimonials = [
  {
    name: "Sarah M.",
    text: "[PLACEHOLDER - Nick to provide Google Review]",
    city: "Oklahoma City"
  },
  {
    name: "Michael R.",
    text: "[PLACEHOLDER - Nick to provide Google Review]",
    city: "Edmond"
  },
  {
    name: "Jennifer L.",
    text: "[PLACEHOLDER - Nick to provide Google Review]",
    city: "Norman"
  }
];

// Format date helper
function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout 
  title="Guardian Cleaners - Expert Cleaning Services in Oklahoma City"
  description="Guardian Cleaners provides professional residential and commercial cleaning services in Oklahoma City, Edmond, Norman and surrounding areas. Book your free estimate today!"
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-gray-50 to-white py-16 md:py-24">
    <div class="absolute inset-0 overflow-hidden">
      <img 
        src="/images/hero-banner.jpg" 
        alt="Guardian Cleaners - Professional Cleaning Services"
        class="w-full h-full object-cover opacity-10"
      />
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          {hero.headline}
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 mb-8">
          {hero.subheadline}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="tel:+14059774237"
            class="bg-[#F56C7E] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#e55a6c] transition-colors duration-200 shadow-lg hover:shadow-xl"
          >
            Call Now
          </a>
          <a 
            href="/contact"
            class="border-2 border-[#F56C7E] text-[#F56C7E] px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#F56C7E] hover:text-white transition-colors duration-200"
          >
            Get a Free Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Summary -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Cleaning Services</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          From routine house cleaning to deep cleaning and move-in/move-out services, we've got you covered.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map(service => (
          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow duration-300">
            <div class="w-full h-40 bg-gray-100 overflow-hidden">
              <img 
                src={service.image} 
                alt={service.alt}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">{service.name}</h3>
              <p class="text-gray-600 text-sm">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-10">
        <a 
          href="/services"
          class="inline-flex items-center text-[#F56C7E] font-semibold hover:underline"
        >
          View All Services
          <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">What Our Clients Say</h2>
        <p class="text-lg text-gray-600">
          [PLACEHOLDER - Nick to provide Google Reviews for testimonials section]
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(testimonial => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="flex items-center mb-4">
              <div class="w-12 h-12 bg-[#F56C7E] rounded-full flex items-center justify-center text-white font-semibold text-lg">
                {testimonial.name.charAt(0)}
              </div>
              <div class="ml-4">
                <p class="font-semibold text-gray-900">{testimonial.name}</p>
                <p class="text-sm text-gray-500">{testimonial.city}</p>
              </div>
            </div>
            <p class="text-gray-600 italic">"{testimonial.text}"</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Proudly Serving the OKC Metro</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Guardian Cleaners is proud to serve residential and commercial clients across the Oklahoma City metropolitan area.
        </p>
      </div>
      
      <div class="flex flex-wrap justify-center gap-3">
        {serviceAreas.map(area => (
          <a 
            href={`/${area.toLowerCase().replace(/\s+/g, '-')}-ok`}
            class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full hover:bg-[#F56C7E] hover:text-white transition-colors duration-200"
          >
            {area}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Latest Blog Posts</h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Cleaning tips, tricks, and insights from Oklahoma City's premier cleaning service.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map(post => (
            <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
              {post.cover_image && (
                <div class="h-48 bg-gray-200 overflow-hidden">
                  <img 
                    src={post.cover_image} 
                    alt={post.excerpt || post.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2">
                  <a href={`/blog/${post.slug}`} class="hover:text-[#F56C7E] transition-colors">
                    {post.title}
                  </a>
                </h3>
                <p class="text-gray-600 text-sm mb-4">
                  {post.excerpt ? post.excerpt.substring(0, 100) + '...' : ''}
                </p>
                <div class="flex items-center justify-between">
                  <time datetime={post.published_at} class="text-sm text-gray-500">
                    {formatDate(post.published_at)}
                  </time>
                  <a 
                    href={`/blog/${post.slug}`}
                    class="text-[#F56C7E] text-sm font-semibold hover:underline"
                  >
                    Read More →
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
        
        <div class="text-center mt-10">
          <a 
            href="/blog"
            class="inline-flex items-center text-[#F56C7E] font-semibold hover:underline"
          >
            View All Posts →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="py-16 md:py-20 bg-[#F56C7E]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready for a Spotless Home?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Experience the difference of professional cleaning. Book your free estimate today!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+14059774237"
          class="bg-white text-[#F56C7E] px-8 py-4 rounded-lg text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg"
        >
          Call Now
        </a>
        <a 
          href="/contact"
          class="border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-[#F56C7E] transition-colors duration-200"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>
</Layout>
