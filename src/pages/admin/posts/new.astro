---
// New post page - SSR, protected by middleware
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import TiptapEditor from '../../../components/TiptapEditor';

// Auth is handled by middleware — no need to check here
// Get error from query params if any
const error = Astro.url.searchParams.get('error');
---

<Layout title="New Post | Guardian Cleaners Admin">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">New Post</h1>
        <p class="text-gray-600 mt-1">Create a new blog post</p>
      </div>
      <a
        href="/admin/dashboard"
        class="text-gray-600 hover:text-gray-900 px-4 py-2"
      >
        ← Back to Dashboard
      </a>
    </header>

    {error && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg">
        Failed to create post. Please try again.
      </div>
    )}

    <form id="post-form" method="POST" action="/api/posts/create" class="space-y-6">
      <div class="bg-white rounded-lg shadow-md p-6 space-y-6">
        {/* Title */}
        <div>
          <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
            Title
          </label>
          <input
            type="text"
            id="title"
            name="title"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Enter post title"
          />
        </div>

        {/* Slug */}
        <div>
          <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">
            Slug
          </label>
          <input
            type="text"
            id="slug"
            name="slug"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="post-url-slug"
          />
          <p class="mt-1 text-sm text-gray-500">
            URL: /blog/<span id="slug-preview">post-url-slug</span>
          </p>
        </div>

        {/* Excerpt */}
        <div>
          <label for="excerpt" class="block text-sm font-medium text-gray-700 mb-1">
            Excerpt
          </label>
          <textarea
            id="excerpt"
            name="excerpt"
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Brief summary of the post"
          ></textarea>
        </div>

        {/* Cover Image */}
        <div>
          <label for="cover_image_file" class="block text-sm font-medium text-gray-700 mb-1">
            Cover Image
          </label>
          <input
            type="file"
            id="cover_image_file"
            accept="image/jpeg,image/png,image/webp"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
          <p class="mt-1 text-sm text-gray-500">
            JPEG, PNG, or WebP. Max 5MB. Recommended size: 1200×675.
          </p>
          <p id="cover-upload-error" class="mt-1 text-sm text-red-600 hidden"></p>
          <p id="cover-upload-success" class="mt-1 text-sm text-green-600 hidden flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span>Image uploaded successfully</span>
          </p>
          <div id="cover-preview" class="mt-2 hidden">
            <div class="relative inline-block">
              <img id="cover-preview-img" src="" alt="Cover preview" class="h-32 w-auto rounded-lg border border-gray-200 object-cover" />
              <button type="button" id="cover-remove-btn" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm hover:bg-red-600 shadow-sm" title="Remove image">&times;</button>
            </div>
          </div>
          <div id="cover-uploading" class="mt-2 hidden flex items-center gap-2 text-sm text-gray-500">
            <svg class="animate-spin h-4 w-4 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            Uploading...
          </div>
          <input type="hidden" id="cover_image" name="cover_image" value="" />
        </div>

        {/* Published */}
        <div class="flex items-center gap-3">
          <input
            type="checkbox"
            id="published"
            name="published"
            value="true"
            class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
          />
          <label for="published" class="text-sm font-medium text-gray-700">
            Publish immediately
          </label>
        </div>

        {/* Content Editor */}
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Content
          </label>
          <TiptapEditor client:only="react" postId="new" hiddenInputId="body_html" />
          <input type="hidden" id="body_html" name="body_html" value="" />
        </div>
      </div>

      {/* Submit */}
      <div class="flex justify-end gap-4">
        <a
          href="/admin/dashboard"
          class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="px-6 py-2 bg-[#F56C7E] text-white rounded-lg hover:bg-[#e55a6c] transition-colors font-medium"
        >
          Create Post
        </button>
      </div>
    </form>
  </main>
</Layout>

<script>
  // Auto-generate slug from title
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;
  const slugPreview = document.getElementById('slug-preview');

  titleInput?.addEventListener('input', () => {
    const slug = titleInput.value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
    slugInput.value = slug;
    if (slugPreview) slugPreview.textContent = slug;
  });

  slugInput?.addEventListener('input', () => {
    if (slugPreview) slugPreview.textContent = slugInput.value;
  });

  // Cover image upload handling
  const coverInput = document.getElementById('cover_image_file') as HTMLInputElement;
  const coverHiddenInput = document.getElementById('cover_image') as HTMLInputElement;
  const coverError = document.getElementById('cover-upload-error') as HTMLParagraphElement;
  const coverSuccess = document.getElementById('cover-upload-success') as HTMLParagraphElement;
  const coverPreview = document.getElementById('cover-preview') as HTMLDivElement;
  const coverPreviewImg = document.getElementById('cover-preview-img') as HTMLImageElement;
  const coverRemoveBtn = document.getElementById('cover-remove-btn') as HTMLButtonElement;
  const coverUploading = document.getElementById('cover-uploading') as HTMLDivElement;
  const form = document.getElementById('post-form') as HTMLFormElement;

  // Use the existing browser Supabase client (picks up auth session from cookies)
  import { createBrowserSupabaseClient } from '../../../lib/supabase';
  const supabase = createBrowserSupabaseClient();

  function resetCoverUI() {
    coverError.classList.add('hidden');
    coverSuccess.classList.add('hidden');
    coverPreview.classList.add('hidden');
    coverUploading.classList.add('hidden');
  }

  coverRemoveBtn?.addEventListener('click', () => {
    resetCoverUI();
    coverHiddenInput.value = '';
    coverInput.value = '';
  });

  coverInput?.addEventListener('change', async () => {
    const file = coverInput.files?.[0];
    if (!file) return;

    resetCoverUI();

    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      coverError.textContent = 'Invalid file type. Please upload JPEG, PNG, or WebP.';
      coverError.classList.remove('hidden');
      coverInput.value = '';
      return;
    }

    // Validate file size (5MB max)
    if (file.size > 5 * 1024 * 1024) {
      coverError.textContent = 'File too large. Maximum size is 5MB.';
      coverError.classList.remove('hidden');
      coverInput.value = '';
      return;
    }

    // Show uploading spinner
    coverUploading.classList.remove('hidden');

    // Upload to Supabase storage using authenticated session
    try {
      const ext = file.name.split('.').pop();
      const fileName = crypto.randomUUID() + '.' + ext;
      
      const { data, error } = await supabase.storage
        .from('blog-images')
        .upload(fileName, file, {
          contentType: file.type,
          upsert: false
        });

      if (error) {
        throw error;
      }

      // Get public URL
      const { data: urlData } = supabase.storage
        .from('blog-images')
        .getPublicUrl(fileName);
      
      coverHiddenInput.value = urlData.publicUrl;

      // Show success + preview
      coverUploading.classList.add('hidden');
      coverSuccess.classList.remove('hidden');
      coverPreviewImg.src = urlData.publicUrl;
      coverPreview.classList.remove('hidden');
    } catch (e) {
      console.error('Upload error:', e);
      coverUploading.classList.add('hidden');
      coverError.textContent = 'Failed to upload image. Please try again.';
      coverError.classList.remove('hidden');
      coverInput.value = '';
    }
  });
</script>
