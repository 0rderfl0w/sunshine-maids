---
// Edit post page - SSR, protected by middleware
export const prerender = false;

import Layout from '../../../../layouts/Layout.astro';
import TiptapEditor from '../../../../components/TiptapEditor';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseServiceKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

// Get post ID from params
const postId = Astro.params.id;

// Auth check via regular client
const supabaseAnon = await import('@supabase/ssr').then(m => 
  m.createServerClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    {
      cookies: {
        get: (key) => Astro.cookies.get(key)?.value,
        set: (key, value, options) => {
          Astro.cookies.set(key, value, options);
        }
      }
    }
  )
);

const { data: { session } } = await supabaseAnon.auth.getSession();

if (!session) {
  return Astro.redirect('/admin/login');
}

// Fetch post using service role client
let post = null;
let fetchError = null;

try {
  const supabaseAdmin = createClient(supabaseUrl, supabaseServiceKey);
  
  const { data, error } = await supabaseAdmin
    .from('posts')
    .select('*')
    .eq('id', postId)
    .single();
  
  if (error) {
    fetchError = error.message;
  } else {
    post = data;
  }
} catch (e: any) {
  fetchError = e.message;
}

if (!post) {
  return Astro.redirect('/admin/dashboard');
}
---

<Layout title={`Edit: ${post.title} | Guardian Cleaners Admin`}>
  <main class="max-w-4xl mx-auto px-4 py-8">
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Edit Post</h1>
        <p class="text-gray-600 mt-1">Update your blog post</p>
      </div>
      <a
        href="/admin/dashboard"
        class="text-gray-600 hover:text-gray-900 px-4 py-2"
      >
        ← Back to Dashboard
      </a>
    </header>

    {fetchError && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg">
        Error loading post: {fetchError}
      </div>
    )}

    <form id="post-form" method="POST" action={`/api/posts/${post.id}`} class="space-y-6">
      <input type="hidden" name="_method" value="PUT" />
      
      <div class="bg-white rounded-lg shadow-md p-6 space-y-6">
        {/* Title */}
        <div>
          <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
            Title
          </label>
          <input
            type="text"
            id="title"
            name="title"
            required
            value={post.title}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Enter post title"
          />
        </div>

        {/* Slug */}
        <div>
          <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">
            Slug
          </label>
          <input
            type="text"
            id="slug"
            name="slug"
            required
            value={post.slug}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="post-url-slug"
          />
          <p class="mt-1 text-sm text-gray-500">
            URL: /blog/<span id="slug-preview">{post.slug}</span>
          </p>
        </div>

        {/* Excerpt */}
        <div>
          <label for="excerpt" class="block text-sm font-medium text-gray-700 mb-1">
            Excerpt
          </label>
          <textarea
            id="excerpt"
            name="excerpt"
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Brief summary of the post"
          >{post.excerpt || ''}</textarea>
        </div>

        {/* Cover Image */}
        <div>
          <label for="cover_image_file" class="block text-sm font-medium text-gray-700 mb-1">
            Cover Image
          </label>
          {post.cover_image && (
            <img src={post.cover_image} alt="Current cover" class="w-32 h-20 object-cover rounded mb-2" />
          )}
          <input
            type="file"
            id="cover_image_file"
            accept="image/jpeg,image/png,image/webp"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
          <p class="mt-1 text-sm text-gray-500">
            JPEG, PNG, or WebP. Max 5MB. Recommended size: 1200×675.
          </p>
          <p id="cover-upload-error" class="mt-1 text-sm text-red-600 hidden"></p>
          <input type="hidden" id="cover_image" name="cover_image" value={post.cover_image || ''} />
        </div>

        {/* Published */}
        <div class="flex items-center gap-3">
          <input
            type="checkbox"
            id="published"
            name="published"
            value="true"
            checked={post.published}
            class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500"
          />
          <label for="published" class="text-sm font-medium text-gray-700">
            Publish immediately
          </label>
        </div>

        {/* Content Editor */}
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Content
          </label>
          <TiptapEditor 
            client:only="react" 
            postId={post.id}
            initialContent={post.body_html || ''}
            hiddenInputId="body_html"
          />
          <input type="hidden" id="body_html" name="body_html" value={post.body_html || ''} />
        </div>
      </div>

      {/* Actions */}
      <div class="flex justify-between gap-4">
        <button
          type="button"
          onclick="if(confirm('Are you sure you want to delete this post?')) { const form = document.createElement('form'); form.method = 'POST'; form.action = '/api/posts/{post.id}'; const input = document.createElement('input'); input.type = 'hidden'; input.name = '_method'; input.value = 'DELETE'; form.appendChild(input); document.body.appendChild(form); form.submit(); }"
          class="px-6 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors"
        >
          Delete Post
        </button>
        
        <div class="flex gap-4">
          <a
            href="/admin/dashboard"
            class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
          >
            Cancel
          </a>
          <button
            type="submit"
            class="px-6 py-2 bg-[#F56C7E] text-white rounded-lg hover:bg-[#e55a6c] transition-colors font-medium"
          >
            Save Changes
          </button>
        </div>
      </div>
    </form>
  </main>
</Layout>

<script define:vars={{ postSlug: post.slug, postId: post.id }}>
  // Auto-generate slug from title
  const titleInput = document.getElementById('title');
  const slugInput = document.getElementById('slug');
  const slugPreview = document.getElementById('slug-preview');

  titleInput?.addEventListener('input', () => {
    const slug = titleInput.value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
    slugInput.value = slug;
    if (slugPreview) slugPreview.textContent = slug;
  });

  slugInput?.addEventListener('input', () => {
    if (slugPreview) slugPreview.textContent = slugInput.value;
  });

  // Cover image upload handling
  const coverInput = document.getElementById('cover_image_file') as HTMLInputElement;
  const coverHiddenInput = document.getElementById('cover_image') as HTMLInputElement;
  const coverError = document.getElementById('cover-upload-error') as HTMLParagraphElement;

  // Use browser Supabase client (picks up auth session from cookies)
  import { createBrowserSupabaseClient } from '../../../lib/supabase';
  const supabase = createBrowserSupabaseClient();

  coverInput?.addEventListener('change', async () => {
    const file = coverInput.files?.[0];
    if (!file) return;

    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      coverError.textContent = 'Invalid file type. Please upload JPEG, PNG, or WebP.';
      coverError.classList.remove('hidden');
      coverInput.value = '';
      return;
    }

    // Validate file size (5MB max)
    if (file.size > 5 * 1024 * 1024) {
      coverError.textContent = 'File too large. Maximum size is 5MB.';
      coverError.classList.remove('hidden');
      coverInput.value = '';
      return;
    }

    coverError.classList.add('hidden');

    // Upload to Supabase storage using authenticated session
    try {
      const ext = file.name.split('.').pop();
      const fileName = crypto.randomUUID() + '.' + ext;
      
      const { data, error } = await supabase.storage
        .from('blog-images')
        .upload(fileName, file, {
          contentType: file.type,
          upsert: false
        });

      if (error) {
        throw error;
      }

      // Get public URL
      const { data: urlData } = supabase.storage
        .from('blog-images')
        .getPublicUrl(fileName);
      
      coverHiddenInput.value = urlData.publicUrl;
      console.log('Cover image uploaded:', urlData.publicUrl);
    } catch (e) {
      console.error('Upload error:', e);
      coverError.textContent = 'Failed to upload image. Please try again.';
      coverError.classList.remove('hidden');
      coverInput.value = '';
    }
  });
</script>
