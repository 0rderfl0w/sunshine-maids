---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Professional Move-In/Move-Out Cleaning Services | Sunshine Maids"
  description="Sunshine Maids makes moving stress-free with thorough move-in and move-out cleaning in Austin. Book your free estimate today!"
  canonical="/services/move-in-move-out-cleaning"
>
  <!-- Hero -->
  <section class="relative min-h-[500px] md:min-h-[600px] flex items-center">
    <div class="absolute inset-0">
      <img 
        src="/images/movein-moveout-cleaning.jpg" 
        alt="Move-in move-out cleaning services"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 max-w-3xl">Professional Move-In/Move-Out Cleaning Services</h1>
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-8">Offering exceptional Move-In/Move-Out Cleaning solutions, our team is committed to providing top-quality services to meet all your needs.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center bg-coral text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+15125550147" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (512) 555-0147
        </a>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
          <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Our Service</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Move-In / Move-Out Cleaning</h2>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            When you're transitioning from one home to another, the last thing you want to worry about is cleaning. That's where Sunshine Maids LLC comes in. Our move-in/move-out cleaning service is designed to take the stress out of your move and ensure you leave your old home sparkling or start fresh in a new one.
          </p>
          <h3 class="font-bold text-text mb-4">Comprehensive Cleaning Coverage:</h3>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Vacuuming and Mopping:</strong> We make sure your floors are spotless, tackling carpets, hardwoods, and tiles alike.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Bathroom Sanitization:</strong> Our experienced cleaners thoroughly sanitize toilets, sinks, and tubs for a pristine finish.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Kitchen Scrubbing:</strong> Countertops, cabinets, and appliances get detailed attention to eliminate grease and grime.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Dusting Everywhere:</strong> Dust doesn't stand a chance as we clean all surfaces, including furniture, baseboards, and light fixtures.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light"><strong class="text-text">Spot Cleaning Walls:</strong> We address visible marks and spots on walls to make them look fresh.</span>
            </li>
          </ul>
          <p class="text-text-light text-lg leading-relaxed">
            Each cleaner we refer is thoroughly vetted, ensuring your peace of mind throughout the service. Booking is straightforward — with one call to (512) 555-0147, you can schedule a cleaning that fits your move timeline.
          </p>
        </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">We make your transition stress-free with our reliable and thorough cleaning service.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <h3 class="font-bold text-text mb-3">Personalized Consultation & Estimate</h3>
          <p class="text-text-light text-sm leading-relaxed">Contact us for a discussion about your cleaning needs. We carefully assess your property and provide a customized quote, ensuring all your requirements are met.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <h3 class="font-bold text-text mb-3">Easy Scheduling & Preparation</h3>
          <p class="text-text-light text-sm leading-relaxed">Choose a convenient date and time for your cleaning. We handle all the planning to align with your schedule, ensuring a seamless process with no last-minute surprises.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <h3 class="font-bold text-text mb-3">Detailed Cleaning Execution</h3>
          <p class="text-text-light text-sm leading-relaxed">Our experienced cleaners perform the agreed tasks with meticulous attention to detail, covering every corner of your home. We aim for excellence in every move-in/move-out cleaning.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">4</span>
          </div>
          <h3 class="font-bold text-text mb-3">Final Inspection & Satisfaction Assurance</h3>
          <p class="text-text-light text-sm leading-relaxed">After cleaning, we conduct a final inspection to ensure everything meets our high standards. Your satisfaction is our priority, and we're committed to leaving your space spotless.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">FAQs</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Common Questions</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What does the Move-In/Move-Out Cleaning service include?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our service covers everything from dusting and vacuuming to scrubbing floors and sanitizing kitchens and bathrooms. We aim to leave your home spotless for the next occupant.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How long does the cleaning service take?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">The time for our service depends on the size and condition of your home. Typically, it takes several hours. We can give you a more precise time estimate when you contact us at (512) 555-0147.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Do I need to be present during the cleaning?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">No, you don't need to be home. Many clients provide access to the property ahead of time. We understand your schedule is busy during a move, and we aim to make it convenient for you.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What areas do you serve?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">We offer services in various locations. It's best to call us at (512) 555-0147 to confirm we service your area.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What should I do to prepare for the cleaning service?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Please ensure any personal belongings are removed before the cleaners arrive. This helps them focus on the cleaning without distractions.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How can I book a Move-In/Move-Out Cleaning?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Booking is easy! Just give us a call at (512) 555-0147, and we'll schedule your cleaning at a time that works for you.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Experience Spotless Living Today!</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Make your move a breeze. Let us handle the cleanup so you can focus on settling in.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Book My Free Estimate
        </a>
        <a href="tel:+15125550147" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (512) 555-0147
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
