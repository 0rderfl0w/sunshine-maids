---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Professional Post-Construction Cleaning Services | Sunshine Maids"
  description="Sunshine Maids handles post-construction cleanup in Austin. Dust removal, detailed surface cleaning, air quality improvement. Book your free estimate today!"
  canonical="/services/post-construction-cleaning"
>
  <!-- Hero -->
  <section class="relative min-h-[500px] md:min-h-[600px] flex items-center">
    <div class="absolute inset-0">
      <img 
        src="/images/post-construction-cleaning.jpg" 
        alt="Post-construction cleaning services"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-20">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 max-w-3xl">Professional Post-Construction Cleaning Services</h1>
      <p class="text-lg md:text-xl text-white/90 max-w-2xl mb-8">Offering exceptional Post-Construction Cleaning solutions, our team is committed to providing top-quality services to meet all your needs.</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center bg-coral text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+15125550147" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (512) 555-0147
        </a>
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
          <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Our Service</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Post-Construction Cleaning</h2>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            At Sunshine Maids LLC, we understand that construction projects can leave behind a significant amount of dust and debris. Our Post-Construction Cleaning service is designed to tackle these challenges, leaving your property in pristine condition. We take pride in delivering high-quality cleaning solutions so that you can enjoy a spotless finish.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            Every construction project is unique, and our cleaning services are tailored to fit the specific requirements of your project, whether it's a small renovation or a large commercial build. We offer flexible scheduling to accommodate your timeline, so our cleaners are available when you need them most.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            Located in Austin, Sunshine Maids LLC is dedicated to ensuring your newly constructed or renovated space shines from top to bottom. Let us handle the mess so you can focus on what comes next.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Thorough dust and debris removal from all surfaces</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Detailed cleaning of fixtures, cabinets, and baseboards</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Air vent cleaning to improve post-construction air quality</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Window, door frame, and light switch detailing</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 rounded-full bg-coral mt-2 flex-shrink-0"></span>
              <span class="text-text-light">Flexible scheduling to fit your construction timeline</span>
            </li>
          </ul>
        </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Ensuring every detail meets your expectations.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <h3 class="font-bold text-text mb-3">Initial Assessment and Proposal</h3>
          <p class="text-text-light text-sm leading-relaxed">We begin with a detailed discussion about your construction project. One of our experts will assess the site and provide a comprehensive proposal, including a clear timeline and customized cost estimate.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <h3 class="font-bold text-text mb-3">Convenient Scheduling</h3>
          <p class="text-text-light text-sm leading-relaxed">Once you're satisfied with our proposal, we arrange a convenient cleaning schedule. Our cleaners will ensure they align their work with your timeline, keeping your priorities in mind.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <h3 class="font-bold text-text mb-3">Comprehensive Cleanup</h3>
          <p class="text-text-light text-sm leading-relaxed">Our experienced cleaners tackle every inch of your project, removing debris and dust. They meticulously clean surfaces, floors, and fixtures, leaving your space spotless and ready for use.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-12 h-12 bg-coral rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-white font-bold text-lg">4</span>
          </div>
          <h3 class="font-bold text-text mb-3">Final Inspection and Client Satisfaction</h3>
          <p class="text-text-light text-sm leading-relaxed">After cleaning, a thorough inspection is performed. We offer a client walkthrough to confirm all areas meet our high standards and your expectations. Your satisfaction is our priority.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">FAQs</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Common Questions</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            What is included in your post-construction cleaning service?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our post-construction cleaning covers dust removal, vacuuming, wiping surfaces, cleaning windows, and detailing every room to make sure your space is safe and spotless.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How long does the post-construction cleaning process take?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">The duration varies based on the size and condition of the space, but we strive to efficiently complete the job to meet your timeline and expectations.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Why should I hire Sunshine Maids LLC instead of doing it myself?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Our experienced cleaners will ensure a thorough job, saving you time and effort. We remove fine dust and debris that can be challenging to clean on your own.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Do I need to be on-site during the cleaning process?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">No, you don't have to be on-site. Our trusted cleaners manage everything, giving you peace of mind.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            Are your cleaners experienced with post-construction environments?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">Yes, they have extensive experience and know how to safely clean construction areas, handling all the necessary equipment and techniques.</p>
        </details>
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-text hover:text-coral transition-colors">
            How can I schedule a post-construction cleaning with Sunshine Maids LLC?
            <svg class="w-5 h-5 text-coral flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-6 text-text-light">It's easy! You can call us at (512) 555-0147 to set up a convenient time for your cleaning service.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Transform Your Space Today</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Contact Sunshine Maids now at (512) 555-0147 for a pristine post-construction clean!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Book My Free Estimate
        </a>
        <a href="tel:+15125550147" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (512) 555-0147
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
