---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About Us - Guardian Cleaners"
  description="Learn about Guardian Cleaners - a locally owned cleaning company serving Oklahoma City, Edmond, Norman and surrounding areas with professional residential and commercial cleaning services."
  canonical="/about"
>
  <!-- Hero -->
  <section class="relative min-h-[50vh] md:min-h-[55vh] flex items-center overflow-hidden">
    <img 
      src="/images/about-hero.png" 
      alt="Beautifully clean modern living room" 
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-white/80 via-white/50 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-16">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text mb-6 max-w-2xl leading-tight">Expert Cleaning and Maid Services</h1>
      <p class="text-lg md:text-xl text-text-light max-w-xl mb-8 leading-relaxed">
        Experience a spotless home with Guardian Cleaners LLC — trustworthy, thorough, and personalized care. Let us handle the mess so you can enjoy your space worry-free.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="bg-coral text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-colors duration-200 shadow-lg text-center">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-coral text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral hover:text-white transition-colors duration-200 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (405) 977-4237
        </a>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">About Guardian Cleaners</h2>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            At Guardian Cleaners, our roots trace back to Oklahoma City with a heartfelt mission: to help our neighbors across the metro enjoy spotless, healthier homes. From OKC, Edmond, and Norman to Moore and beyond, we're here to transform living and working spaces into immaculate oases.
          </p>
          <p class="text-text-light text-lg leading-relaxed">
            Our approach is simple yet profound — we don't cut corners, we clean them. By partnering with skilled local cleaners, we provide opportunities that strengthen our community. Our commitment is more than just professional service; it's building trust and fostering relationships. Experience the warmth and reliability we've been proud to offer, backed by a legacy of integrity and dedication.
          </p>
        </div>
        <div>
          <img 
            src="/images/cleaning-team.png" 
            alt="The Guardian Cleaners team"
            class="w-full rounded-2xl shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Why Us</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">The Guardian Difference</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-16 h-16 bg-coral/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Locally Owned</h3>
          <p class="text-text-light text-sm">Proud to serve our Oklahoma community</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-16 h-16 bg-coral/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Flexible Scheduling</h3>
          <p class="text-text-light text-sm">We work around your schedule</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-16 h-16 bg-coral/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Trusted Professionals</h3>
          <p class="text-text-light text-sm">Background-checked cleaning experts</p>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-md text-center">
          <div class="w-16 h-16 bg-coral/10 rounded-full flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <h3 class="font-bold text-text mb-2">Satisfaction Guaranteed</h3>
          <p class="text-text-light text-sm">We don't leave until you're happy</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-coral animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Experience the Guardian Difference</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Ready to enjoy a cleaner, healthier home? Let us take care of the work so you can focus on what matters.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (405) 977-4237
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
