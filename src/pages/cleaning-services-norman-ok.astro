---
import Layout from '../layouts/Layout.astro';

const neighborhoods = [
  "Campus Corner",
  "Brookhaven",
  "Brookway Estates",
  "Briarwood",
  "University",
  "Lincoln Park",
  "Legacy Park",
  "Westlake",
  "Cedar Creek",
  "Parkway Estates",
  "The Greens",
  "Canyon Ridge"
];

// Norman-specific schema
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Guardian Cleaners",
  "telephone": "+1-405-977-4237",
  "email": "nik@guardian-cleaners.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3129 NW 14th St",
    "addressLocality": "Oklahoma City",
    "addressRegion": "OK",
    "postalCode": "73107"
  },
  "areaServed": ["Norman, OK", ...neighborhoods.map(n => `${n}, Norman, OK`)],
  "priceRange": "$$"
};
---

<Layout 
  title="House Cleaning Services in Norman, OK | Guardian Cleaners"
  description="Professional house cleaning services in Norman, OK. Guardian Cleaners serves Campus Corner, Brookhaven, Brookway Estates, and all Norman neighborhoods. Specializing in student rental turnovers. Book today!"
  canonical="/cleaning-services-norman-ok"
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-gray-50 to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          House Cleaning in Norman, OK
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional residential cleaning services in Norman, Oklahoma. From student rental turnovers to family homes, we deliver spotless results every time.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="tel:+14059774237"
            class="bg-[#F56C7E] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#e55a6c] transition-colors duration-200 shadow-lg hover:shadow-xl"
          >
            Call Now
          </a>
          <a 
            href="/contact"
            class="border-2 border-[#F56C7E] text-[#F56C7E] px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[#F56C7E] hover:text-white transition-colors duration-200"
          >
            Get a Free Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          Your Trusted Norman House Cleaning Service
        </h2>
        
        <div class="prose prose-lg text-gray-600 mb-10">
          <p>
            Norman, Oklahoma is a vibrant college town home to the University of Oklahoma. At Guardian Cleaners, we understand what makes Norman's cleaning needs unique. Whether you're a professor living near campus, a family in one of Norman's established neighborhoods, or a property manager handling student rentals, we have the expertise to handle your cleaning needs.
          </p>
          <p>
            One of our specialties in Norman is move-in and move-out cleaning for student rentals. With thousands of students cycling through apartments and houses near Campus Corner and the university area each semester, there's always demand for thorough turnover cleanings. We work with property managers, landlords, and students alike to ensure rentals are spotless for the next occupants.
          </p>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          Norman Neighborhoods We Serve
        </h2>
        
        <p class="text-gray-600 mb-6">
          We proudly provide house cleaning services to residents across all Norman communities, including:
        </p>
        
        <div class="flex flex-wrap gap-3 mb-10">
          {neighborhoods.map(area => (
            <span class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full">
              {area}
            </span>
          ))}
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          Why Norman Chooses Guardian Cleaners
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="bg-gray-50 p-6 rounded-lg">
            <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Student Rental Specialists</h3>
            <p class="text-gray-600 text-sm">We excel at move-in/move-out cleanings for student rentals near OU. Fast turnarounds during peak seasons so landlords can re-rent quickly.</p>
          </div>
          
          <div class="bg-gray-50 p-6 rounded-lg">
            <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Flexible Scheduling</h3>
            <p class="text-gray-600 text-sm">We work around class schedules, work shifts, and semester deadlines. Need a same-day turnaround? We can often accommodate.</p>
          </div>
          
          <div class="bg-gray-50 p-6 rounded-lg">
            <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Insured & Background Checked</h3>
            <p class="text-gray-600 text-sm">Every cleaner is thoroughly vetted. Property managers trust us with their units, and homeowners trust us with their families.</p>
          </div>
          
          <div class="bg-gray-50 p-6 rounded-lg">
            <div class="w-12 h-12 bg-[#F56C7E] rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Satisfaction Guaranteed</h3>
            <p class="text-gray-600 text-sm">We're not happy unless you're happy. If anything falls short, we'll make it right, no questions asked.</p>
          </div>
        </div>

        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          Frequently Asked Questions
        </h2>
        
        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">Do you handle move-out cleanings for student rentals in Norman?</h3>
            <p class="text-gray-600">Yes! This is one of our specialties. We understand the fast turnarounds needed between tenants, especially at semester changes. Contact us for quick turnaround times.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">How much does house cleaning cost in Norman?</h3>
            <p class="text-gray-600">Pricing depends on your home's size and the type of service you need. We offer competitive rates for everything from basic cleanings to deep moves.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">Do you work with Norman property managers?</h3>
            <p class="text-gray-600">Absolutely. We have experience working with property management companies and landlords throughout Norman, handling turnover cleanings for multiple units.</p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">Can you clean while classes are in session?</h3>
            <p class="text-gray-600">Yes! We offer flexible scheduling that works around class schedules. We can clean while you're at class or work, so there's minimal disruption to your routine.</p>
          </div>
        </div>

        <!-- Local Testimonial Placeholder -->
        <div class="mt-12 bg-gray-50 p-8 rounded-lg border-l-4 border-[#F56C7E]">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#F56C7E] rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-600 italic mb-3">"Guardian Cleaners has been handling our student rental turnovers for years. They're reliable, thorough, and always deliver on time. Couldn't ask for a better cleaning partner in Norman."</p>
              <p class="font-semibold text-gray-900">— Norman Property Manager</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-[#F56C7E]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready for a Cleaner Norman Home?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Contact Guardian Cleaners today for professional house cleaning services in Norman, Oklahoma.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+14059774237"
          class="bg-white text-[#F56C7E] px-8 py-4 rounded-lg text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg"
        >
          Call Now
        </a>
        <a 
          href="/contact"
          class="border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-[#F56C7E] transition-colors duration-200"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>
</Layout>
