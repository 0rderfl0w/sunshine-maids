---
// Homepage - SSR to fetch latest blog posts
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { createServerClient } from '@supabase/ssr';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

// Create server client
const supabase = createServerClient(
  supabaseUrl,
  supabaseKey,
  {
    cookies: {
      get: (key) => Astro.cookies.get(key)?.value,
      set: (key, value, options) => {
        Astro.cookies.set(key, value, options);
      }
    }
  }
);

// Fetch latest 3 published posts
let latestPosts: any[] = [];
try {
  const { data, error } = await supabase
    .from('posts')
    .select('id, title, slug, excerpt, cover_image, published_at')
    .eq('published', true)
    .order('published_at', { ascending: false })
    .limit(3);
  
  if (!error && data) {
    latestPosts = data;
  }
} catch (e) {
  console.error('Error fetching posts:', e);
}

const services = [
  { name: "Basic House Cleaning", href: "/services/basic-house-cleaning", image: "/images/basic-house-cleaning.jpg", alt: "Basic house cleaning in Austin" },
  { name: "Deep House Cleaning", href: "/services/deep-house-cleaning", image: "/images/deep-house-cleaning.jpg", alt: "Deep house cleaning in Austin" },
  { name: "Move-In/Move-Out Cleaning", href: "/services/move-in-move-out-cleaning", image: "/images/movein-moveout-cleaning.jpg", alt: "Move-in move-out cleaning in Austin" },
  { name: "Recurring Maid Services", href: "/services/recurring-maid-services", image: "/images/recurring-maid-services.jpg", alt: "Recurring maid services in Austin" },
  { name: "Airbnb Cleaning", href: "/services/airbnb-cleaning", image: "/images/airbnb-cleaning.jpg", alt: "Airbnb cleaning in Austin" },
  { name: "Commercial Cleaning", href: "/services/commercial-cleaning", image: "/images/commercial-cleaning.jpg", alt: "Commercial cleaning in Austin" },
  { name: "Post-Construction Cleaning", href: "/services/post-construction-cleaning", image: "/images/post-construction-cleaning.jpg", alt: "Post-construction cleaning in Austin" },
];

const serviceAreas = [
  { name: "Austin", href: "/house-cleaning-austin-tx" },
  { name: "Round Rock", href: "/cleaning-services-round-rock-tx" },
  { name: "Cedar Park", href: "/cleaning-services-cedar-park-tx" },
  { name: "Pflugerville", href: "/cleaning-services-pflugerville-tx" },
  { name: "Georgetown", href: "#" },
  { name: "Bee Cave", href: "#" },
  { name: "Lakeway", href: "#" },
  { name: "Kyle", href: "#" },
  { name: "Buda", href: "#" },
];

const testimonials = [
  { name: "Tanya R.", text: "Sunshine Maids did an incredible job with my move-out clean in South Congress. I was stressed about my deposit and they came in and made the place look brand new. 100% recommend." },
  { name: "Marcus D.", text: "Great service, great communication. I've used them twice now for deep cleans and will definitely use them again. Very thorough and professional." },
  { name: "Jessica L.", text: "I had never hired a cleaning service before but after this experience I don't know how I lived without it. Absolutely spotless results every time." },
  { name: "Carlos M.", text: "Amazing team. Super detail-oriented and they work fast. My house off Burnet Road has never looked this good. Highly recommend for anyone in the Austin area." },
  { name: "Rachel T.", text: "Used Sunshine Maids for my Airbnb in East Austin and the turnaround was perfect. Guests always comment on how clean the place is. Worth every penny." },
  { name: "David W.", text: "Fantastic service. Attention to detail is unreal — they got spots I haven't touched in years. Great customer service too. Very happy." },
  { name: "Amy K.", text: "Had a short timeline before family came to visit but they got me in last minute. Everything was spotless as promised. Will be booking monthly from now on." },
  { name: "Priya S.", text: "The team was professional, friendly, and listened to exactly what I needed. My home in Mueller felt completely refreshed after their visit." },
  { name: "Lisa H.", text: "Maria and the crew did a thorough deep clean before we listed our home. The realtor was blown away. Absolutely worth it." },
  { name: "James F.", text: "I booked Sunshine Maids for a deep cleaning and wow — they knocked it out of the park. My place has never looked this good. They got every spot I always miss." },
  { name: "Keisha B.", text: "They worked all day getting our Travis Heights house in perfect shape before a big party. Professional, hardworking, and the results were outstanding. Would give 10 stars if I could." },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout 
  title="Sunshine Maids - Expert Cleaning Services in Austin"
  description="Sunshine Maids provides professional residential and commercial cleaning services in Austin, Round Rock, Cedar Park and surrounding areas. Book your free estimate today!"
>
  <!-- Hero Section -->
  <section class="relative min-h-[600px] md:min-h-[700px] flex items-center">
    <div class="absolute inset-0">
      <img 
        src="/images/hero.jpg" 
        alt="Clean modern living room — Sunshine Maids"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center w-full">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Expert Cleaning Services<br/>for Your Home
      </h1>
      <p class="text-xl md:text-2xl text-white/90 mb-10 max-w-2xl mx-auto">
        Reliable and local cleaning for OKC homes and businesses
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact"
          class="bg-coral text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-coral-dark transition-colors duration-200 shadow-lg"
        >
          Book My Free Estimate
        </a>
        <a 
          href="tel:+14059774237"
          class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200"
        >
          Call Now (512) 555-0147
        </a>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Services</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Our Expert Cleaning Services</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        {services.slice(0, 3).map(service => (
          <a href={service.href} class="group relative h-64 rounded-xl overflow-hidden block">
            <img src={service.image} alt={service.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-white text-xl font-bold">{service.name}</h3>
              <span class="text-white/80 text-sm font-medium mt-1 inline-block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.slice(3).map(service => (
          <a href={service.href} class="group relative h-56 rounded-xl overflow-hidden block">
            <img src={service.image} alt={service.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="text-white text-lg font-bold">{service.name}</h3>
              <span class="text-white/80 text-sm font-medium mt-1 inline-block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Wave divider -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- Our Story Section -->
  <section class="bg-coral py-16 md:py-24 animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Our Story</h2>
          <p class="text-white/90 text-lg leading-relaxed mb-6">
            At Sunshine Maids, our roots trace back to Austin with a heartfelt mission: to help our neighbors across the metro enjoy spotless, healthier homes. From South Austin and Bee Cave to Round Rock and Pflugerville, we're here to transform living and working spaces into immaculate oases.
          </p>
          <p class="text-white/90 text-lg leading-relaxed">
            Our approach is simple yet profound — we don't cut corners, we clean them. By partnering with skilled local cleaners, we provide opportunities that strengthen our community. Experience the warmth and reliability we've been proud to offer, backed by a legacy of integrity and dedication.
          </p>
        </div>
        <div>
          <img 
            src="/images/our-story.jpg" 
            alt="Sunshine Maids — our story"
            class="w-full rounded-2xl shadow-xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave divider back to white -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" style="margin-top: -1px;">
      <path d="M0 0H1440V40C1080 80 720 0 360 40C180 60 60 50 0 40V0Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- Service Areas Section -->
  <section class="py-16 md:py-20 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Locations</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">Proudly Serving the OKC Metro</h2>
        <p class="text-text-light text-lg max-w-2xl mx-auto">
          Sunshine Maids serves residential and commercial clients across the Austin metropolitan area.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {serviceAreas.map(area => (
          <a href={area.href} class="px-5 py-2.5 bg-coral/10 text-coral rounded-full font-medium border border-coral/20 hover:bg-coral hover:text-white transition-colors duration-200">
            {area.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-16 md:py-20 bg-gray-50 animate-on-scroll overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-4">
        <span class="inline-block bg-coral/10 text-coral font-semibold uppercase tracking-widest text-xs px-4 py-1.5 rounded-full mb-4">Testimonials</span>
        <h2 class="text-3xl md:text-4xl font-bold text-text mb-2">What Our Clients Say</h2>
        <p class="text-text-light">Real reviews from real customers</p>
      </div>
      <div class="flex items-center justify-center gap-1 mb-10">
        {[1,2,3,4,5].map(() => (
          <svg class="w-7 h-7 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        ))}
        <span class="ml-2 text-text font-semibold text-lg">5.0</span>
        <a href="https://maps.app.goo.gl/iiC1g7rU36rYkN4V7" target="_blank" rel="noopener noreferrer" class="text-text-light ml-1 underline hover:text-coral transition-colors">(103 reviews)</a>
      </div>
    </div>

    <!-- Scrolling carousel -->
    <div class="relative" id="testimonial-carousel">
      <!-- Fade edges -->
      <div class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none"></div>

      <!-- Track -->
      <div class="flex gap-6 testimonial-track" style="width: max-content;">
        {/* Duplicate the set for seamless loop */}
        {[...testimonials, ...testimonials].map((t, i) => (
          <div class="w-[340px] md:w-[400px] flex-shrink-0 bg-white rounded-2xl p-7 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 cursor-default select-none">
            <div class="flex items-center mb-4">
              <div class="w-11 h-11 bg-coral rounded-full flex items-center justify-center text-white font-bold text-base flex-shrink-0">
                {t.name.charAt(0)}
              </div>
              <div class="ml-3">
                <p class="font-semibold text-text text-sm">{t.name}</p>
                <div class="flex gap-0.5 mt-0.5">
                  {[1,2,3,4,5].map(() => (
                    <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
              </div>
            </div>
            <p class="text-text-light text-sm leading-relaxed line-clamp-4">"{t.text}"</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Nav dots / pause -->
    <div class="flex justify-center mt-8 gap-3">
      <button id="testimonial-pause" class="text-text-light hover:text-coral transition-colors p-2" aria-label="Pause testimonials">
        <svg class="w-5 h-5" id="pause-icon" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
        <svg class="w-5 h-5 hidden" id="play-icon" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/></svg>
      </button>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  {latestPosts.length > 0 && (
    <section class="py-16 md:py-20 bg-white animate-on-scroll">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-coral font-semibold uppercase tracking-widest text-sm mb-3">Blog</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">Latest Blog Posts</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {latestPosts.map(post => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-lg transition-shadow">
              {post.cover_image && (
                <div class="h-48 overflow-hidden">
                  <img src={post.cover_image} alt={post.excerpt || post.title} class="w-full h-full object-cover" />
                </div>
              )}
              <div class="p-6">
                <h3 class="text-xl font-semibold text-text mb-2">
                  <a href={`/blog/${post.slug}`} class="hover:text-coral transition-colors">{post.title}</a>
                </h3>
                <p class="text-text-light text-sm mb-4">
                  {post.excerpt ? post.excerpt.substring(0, 100) + '...' : ''}
                </p>
                <div class="flex items-center justify-between">
                  <time datetime={post.published_at} class="text-sm text-text-light">{formatDate(post.published_at)}</time>
                  <a href={`/blog/${post.slug}`} class="text-coral text-sm font-semibold hover:underline">Read More →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/blog" class="text-coral font-semibold hover:underline">View All Posts →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Wave: white → coral -->
  <div class="bg-white">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C360 80 720 0 1080 40C1260 60 1380 50 1440 40V80H0V40Z" fill="#E56B6F"/>
    </svg>
  </div>

  <!-- CTA Banner -->
  <section class="py-14 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready for a Spotless Home?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Experience the difference of professional cleaning. Book your free estimate today!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Book My Free Estimate
        </a>
        <a href="tel:+14059774237" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call Now (512) 555-0147
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .testimonial-track {
    animation: scroll-left 60s linear infinite;
  }
  .testimonial-track:hover {
    animation-play-state: paused;
  }
  .testimonial-track.paused {
    animation-play-state: paused;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

  // Testimonial carousel pause/play
  const pauseBtn = document.getElementById('testimonial-pause');
  const pauseIcon = document.getElementById('pause-icon');
  const playIcon = document.getElementById('play-icon');
  const track = document.querySelector('.testimonial-track');

  if (pauseBtn && track) {
    let isPaused = false;
    pauseBtn.addEventListener('click', () => {
      isPaused = !isPaused;
      track.classList.toggle('paused', isPaused);
      pauseIcon?.classList.toggle('hidden', isPaused);
      playIcon?.classList.toggle('hidden', !isPaused);
    });
  }
</script>
