---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    name: "Basic House Cleaning",
    href: "/services/basic-house-cleaning",
    description: "At Sunshine Maids LLC, we understand that maintaining a clean home is crucial for your comfort and well-being. Our Basic House Cleaning service covers routine tasks with precision and care, allowing you more free time to do what you love.",
    features: ["Dusting all surfaces", "Vacuuming floors", "Scrubbing bathroom fixtures", "Thoroughly cleaning kitchen areas", "Attention to often-forgotten nooks and crannies"],
    image: "/images/basic-house-cleaning.jpg",
    alt: "Basic house cleaning in Austin — Sunshine Maids"
  },
  {
    name: "Deep House Cleaning",
    href: "/services/deep-house-cleaning",
    description: "Our Deep House Cleaning service is designed to bring your home back to its immaculate state. Our skilled cleaners take the time to address every nook and cranny, ensuring no corner is untouched.",
    features: ["Comprehensive dusting including ceiling fans and baseboards", "Disinfecting high-touch areas", "Detailed kitchen refresh — appliances, cabinets, countertops", "Bathroom revival — grout lines and shower fixtures", "Floor perfection — tile, wood, and carpet"],
    image: "/images/deep-house-cleaning.jpg",
    alt: "Deep house cleaning in Austin — Sunshine Maids"
  },
  {
    name: "Move-In/Move-Out Cleaning",
    href: "/services/move-in-move-out-cleaning",
    description: "Comprehensive cleaning service designed for those transitioning between homes. Ensures your old place is spotless for the next occupant or your new home is ready for you to move in.",
    features: ["Complete interior cleaning", "Kitchen deep clean", "Bathroom sanitization", "Floor care — all surfaces", "Window cleaning"],
    image: "/images/movein-moveout-cleaning.jpg",
    alt: "Move-in/move-out cleaning in Austin — Sunshine Maids"
  },
  {
    name: "Recurring Maid Services",
    href: "/services/recurring-maid-services",
    description: "Regular scheduled cleaning services to maintain your home's cleanliness consistently. Flexible scheduling to fit your lifestyle.",
    features: ["Weekly, bi-weekly, or monthly visits", "Customized cleaning plans", "Consistent quality", "Reliable and courteous professionals"],
    image: "/images/recurring-maid-services.jpg",
    alt: "Recurring maid services in Austin — Sunshine Maids"
  },
  {
    name: "Airbnb Cleaning",
    href: "/services/airbnb-cleaning",
    description: "Seamless turnarounds that delight your guests every time. We specialize in delivering cleaning solutions for short-term rental properties.",
    features: ["Flexible scheduling for quick turnarounds", "Detailed cleaning — kitchen, bathrooms, bedrooms", "Fresh linens and towels", "Inspection and restocking supplies", "Trash removal and bin lining"],
    image: "/images/airbnb-cleaning.jpg",
    alt: "Airbnb cleaning in Austin — Sunshine Maids"
  },
  {
    name: "Commercial Cleaning",
    href: "/services/commercial-cleaning",
    description: "Professional cleaning services for business spaces. We help maintain a clean and productive environment for your employees and customers.",
    features: ["Office cleaning", "Commercial space sanitization", "Flexible scheduling", "Professional and reliable staff"],
    image: "/images/commercial-cleaning.jpg",
    alt: "Commercial cleaning in Austin — Sunshine Maids"
  },
  {
    name: "Post-Construction Cleaning",
    href: "/services/post-construction-cleaning",
    description: "Specialized cleaning service after renovation or construction work. We handle the mess so you can enjoy your newly renovated space.",
    features: ["Dust and debris removal", "Deep cleaning of all surfaces", "Window cleaning", "Floor care and polishing", "Final detail work"],
    image: "/images/post-construction-cleaning.jpg",
    alt: "Post-construction cleaning in Austin — Sunshine Maids"
  }
];
---

<Layout 
  title="Professional Cleaning Services - Sunshine Maids"
  description="Sunshine Maids offers comprehensive cleaning services including basic house cleaning, deep cleaning, move-in/move-out, Airbnb, commercial, and post-construction cleaning in Austin."
  canonical="/services"
>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 bg-coral">
    <div class="absolute top-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" style="margin-bottom: -1px;">
        <path d="M0 60H1440V0C1200 40 960 60 720 30C480 0 240 20 0 50V60Z" fill="white"/>
      </svg>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <p class="text-white/80 font-semibold uppercase tracking-widest text-sm mb-3">What We Offer</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Our Cleaning Services</h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto">
        Professional residential and commercial cleaning solutions tailored to your needs.
      </p>
    </div>
  </section>

  <!-- Service Cards Grid -->
  <section class="py-16 md:py-24 bg-white animate-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        {services.slice(0, 3).map(service => (
          <a href={service.href} class="group relative h-64 rounded-xl overflow-hidden block">
            <img src={service.image} alt={service.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-white text-xl font-bold">{service.name}</h3>
              <span class="text-white/80 text-sm font-medium mt-1 inline-block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.slice(3).map(service => (
          <a href={service.href} class="group relative h-56 rounded-xl overflow-hidden block">
            <img src={service.image} alt={service.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="text-white text-lg font-bold">{service.name}</h3>
              <span class="text-white/80 text-sm font-medium mt-1 inline-block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Detailed Service Descriptions -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-20">
        {services.map((service, index) => (
          <div id={service.name.toLowerCase().replace(/[\s\/]+/g, '-')} class="animate-on-scroll flex flex-col lg:flex-row gap-10 items-center">
            <div class={`w-full lg:w-5/12 ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
              <div class="w-full aspect-4/3 rounded-2xl overflow-hidden shadow-lg">
                <img src={service.image} alt={service.alt} class="w-full h-full object-cover" />
              </div>
            </div>
            <div class={`w-full lg:w-7/12 ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
              <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">{service.name}</h2>
              <p class="text-text-light text-lg mb-6 leading-relaxed">{service.description}</p>
              <h3 class="font-semibold text-text mb-3">What's Included:</h3>
              <ul class="space-y-2 mb-6">
                {service.features.map(feature => (
                  <li class="flex items-center text-text-light">
                    <svg class="w-5 h-5 mr-3 text-coral flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <a
                href={service.href}
                class="inline-flex items-center gap-2 bg-coral text-white px-6 py-2.5 rounded-full font-semibold hover:bg-coral-dark transition-colors duration-200"
              >
                Learn More →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-coral">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Need a Custom Cleaning Solution?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Contact us today to discuss your specific cleaning needs. We'll create a personalized cleaning plan just for you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-coral px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 transition-colors duration-200 shadow-lg">
          Book My Free Estimate
        </a>
        <a href="tel:+15125550147" class="border-2 border-white text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-white hover:text-coral transition-colors duration-200">
          Call (512) 555-0147
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
