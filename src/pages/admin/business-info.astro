---
// Business info page - SSR, protected by middleware
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { createServerClient } from '@supabase/ssr';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const supabase = createServerClient(
  supabaseUrl,
  supabaseKey,
  {
    cookies: {
      get: (key) => Astro.cookies.get(key)?.value,
      set: (key, value, options) => {
        Astro.cookies.set(key, value, options);
      }
    }
  }
);

// Check auth
const { data: { session } } = await supabase.auth.getSession();

if (!session) {
  return Astro.redirect('/admin/login');
}

// Check for success/error from redirect
const saved = Astro.url.searchParams.get('saved') === '1';
const error = Astro.url.searchParams.get('error');

// Fetch site config
let config: Record<string, string> = {};
try {
  const { data, error: fetchError } = await supabase
    .from('site_config')
    .select('key, value');
  
  if (!fetchError && data) {
    data.forEach((item: { key: string; value: string }) => {
      config[item.key] = item.value;
    });
  }
} catch (e) {
  console.error('Error fetching config:', e);
}
---

<Layout title="Business Info | Sunshine Maids Admin">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Business Info</h1>
        <p class="text-gray-600 mt-1">Manage your business details</p>
      </div>
      <a
        href="/admin/dashboard"
        class="text-gray-600 hover:text-gray-900 px-4 py-2"
      >
        ← Back to Dashboard
      </a>
    </header>

    {saved && (
      <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg">
        Business info saved successfully!
      </div>
    )}

    {error && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg">
        Failed to save. Please try again.
      </div>
    )}

    <form method="POST" action="/api/admin/business-info" class="space-y-6">
      <div class="bg-white rounded-lg shadow-md p-6 space-y-6">
        {/* Phone */}
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
            Phone
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            value={config.phone || ''}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="(512) 555-0147"
          />
        </div>

        {/* Email */}
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            value={config.email || ''}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="hello@sunshinemaids.com"
          />
        </div>

        {/* Address */}
        <div>
          <label for="address" class="block text-sm font-medium text-gray-700 mb-1">
            Address
          </label>
          <input
            type="text"
            id="address"
            name="address"
            value={config.address || ''}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="1847 South Lamar Blvd, Austin, TX 78704"
          />
        </div>

        {/* Business Hours */}
        <div>
          <label for="business_hours" class="block text-sm font-medium text-gray-700 mb-1">
            Business Hours
          </label>
          <input
            type="text"
            id="business_hours"
            name="business_hours"
            value={config.business_hours || ''}
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Mon-Fri 8am-6pm, Sat 9am-4pm"
          />
        </div>

        {/* Service Areas */}
        <div>
          <label for="service_areas" class="block text-sm font-medium text-gray-700 mb-1">
            Service Areas
          </label>
          <textarea
            id="service_areas"
            name="service_areas"
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Austin, Round Rock, Cedar Park..."
          >{config.service_areas || ''}</textarea>
          <p class="mt-1 text-sm text-gray-500">
            Separate areas with commas
          </p>
        </div>
      </div>

      {/* Submit */}
      <div class="flex justify-end gap-4">
        <a
          href="/admin/dashboard"
          class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="px-6 py-2 bg-[#F56C7E] text-white rounded-lg hover:bg-[#e55a6c] transition-colors font-medium"
        >
          Save Changes
        </button>
      </div>
    </form>
  </main>
</Layout>